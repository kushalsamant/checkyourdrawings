# Backend (optional - defaults work for local dev)
# CYD_MAX_FILE_SIZE_MB=100
# CYD_PDF_DPI=300
# CYD_MAX_IMAGE_PIXELS=50000000
# CYD_MAX_IMAGE_DIMENSION=12000
# CYD_OUTPUT_MAX_AGE_HOURS=24
# CYD_COMPARE_TIMEOUT_SECONDS=300
# CYD_CONTENT_BBOX_PADDING_RATIO=0.02
# CYD_MIN_OVERLAP_AREA_RATIO=0.05
# CYD_ALIGNMENT_MARGINAL_INLIER_RATIO=0.55
# CYD_ALIGNMENT_ECC_REFINEMENT=true
# CYD_CORS_ORIGINS is comma-separated (not JSON), e.g. url1,url2
# CYD_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Production (set on Render)
# CYD_CORS_ORIGINS=https://checkyourdrawings.kvshvl.in,https://www.checkyourdrawings.kvshvl.in

# Local inbox script (scripts/read_service_inbox.py) - gitignored values in .env
# GMAIL_IMAP_USER=you@gmail.com
# GMAIL_IMAP_APP_PASSWORD=xxxx xxxx xxxx xxxx
